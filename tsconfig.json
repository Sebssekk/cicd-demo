{
  "compilerOptions": {
    /* Basic Options */
    "target": "ES2022",                /* Target modern Node.js environments */
    "module": "CommonJS",              /* Standard module system for Node/Express */
    "outDir": "./dist",                /* Where tsgo will output the compiled JS */
    "rootDir": "./src",                /* Where tsgo should look for source files */

    /* Strict Type-Checking Options */
    "strict": true,                    /* Enable all strict type-checking options */
    "noImplicitAny": true,             /* Raise error on expressions with an implied 'any' type */
    "strictNullChecks": true,          /* Enable strict null checks */

    /* Module Resolution Options */
    "esModuleInterop": true,           /* Enables interoperability between CommonJS and ES Modules */
    "forceConsistentCasingInFileNames": true,

    /* Advanced */
    "skipLibCheck": true,             /* Skip type checking of declaration files (.d.ts) for faster builds */

    "types": ["jest", "node"]
  },
  "include": [
    "src/**/*"                         /* Only compile files in the src directory */
  ],
  "exclude": [
    "node_modules",
    "tests",                           /* Exclude tests from the final production build */
    "**/*.test.ts"
  ]
}